<?xml version="1.0" encoding="utf-8"?>
<com.google.android.material.card.MaterialCardView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    style="@style/Widget.FreeAirRadio.DialogCard"
    android:layout_width="match_parent"
    android:layout_height="wrap_content">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="@dimen/dialog_content_padding">

        <TextView
            android:id="@+id/station_details_name"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginHorizontal="@dimen/dialog_title_horizontal_margin"
            android:breakStrategy="balanced"
            android:ellipsize="end"
            android:gravity="center"
            android:hyphenationFrequency="normal"
            android:maxLines="3"
            android:textAlignment="center"
            android:textAppearance="@style/TextAppearance.FreeAirRadio.DialogTitle"
            tools:ignore="VisualLintSystemUi" />

        <com.google.android.material.card.MaterialCardView
            style="@style/Widget.FreeAirRadio.DialogSectionCard"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/dialog_section_margin_top">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical">

                <com.matijakljajic.freeairradio.ui.stations.StationDetailRowView
                    android:id="@+id/row_country"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content" />
                <com.matijakljajic.freeairradio.ui.stations.StationDetailRowView
                    android:id="@+id/row_language"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content" />
                <com.matijakljajic.freeairradio.ui.stations.StationDetailRowView
                    android:id="@+id/row_codec"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content" />
                <com.matijakljajic.freeairradio.ui.stations.StationDetailRowView
                    android:id="@+id/row_bitrate"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content" />
                <com.matijakljajic.freeairradio.ui.stations.StationDetailRowView
                    android:id="@+id/row_tags"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content" />
                <com.matijakljajic.freeairradio.ui.stations.StationDetailRowView
                    android:id="@+id/row_stream_url"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content" />
                <com.matijakljajic.freeairradio.ui.stations.StationDetailRowView
                    android:id="@+id/row_homepage"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content" />

            </LinearLayout>

        </com.google.android.material.card.MaterialCardView>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/dialog_primary_button_margin_top"
            android:orientation="horizontal">

            <com.google.android.material.button.MaterialButton
                android:id="@+id/station_details_favorite_button"
                style="@style/Widget.FreeAirRadio.DialogSecondaryButton"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="@string/player_favorite_button" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/station_details_ok_button"
                style="@style/Widget.FreeAirRadio.DialogPrimaryButton"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginStart="10dp"
                android:layout_weight="1"
                android:text="@string/station_details_close" />

        </LinearLayout>

    </LinearLayout>

</com.google.android.material.card.MaterialCardView>
