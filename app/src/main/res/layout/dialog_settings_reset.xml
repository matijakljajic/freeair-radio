<?xml version="1.0" encoding="utf-8"?>
<com.google.android.material.card.MaterialCardView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    style="@style/Widget.FreeAirRadio.DialogCard"
    android:layout_width="match_parent"
    android:layout_height="wrap_content">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="@dimen/dialog_content_padding">

        <TextView
            android:id="@+id/settings_reset_dialog_title"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginHorizontal="@dimen/dialog_title_horizontal_margin"
            android:breakStrategy="balanced"
            android:gravity="center"
            android:textAlignment="center"
            android:textAppearance="@style/TextAppearance.FreeAirRadio.DialogTitle" />

        <com.google.android.material.card.MaterialCardView
            style="@style/Widget.FreeAirRadio.DialogSectionCard"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/dialog_section_margin_top">

            <TextView
                android:id="@+id/settings_reset_dialog_message"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:gravity="start"
                android:padding="@dimen/dialog_section_padding"
                android:textAppearance="?attr/textAppearanceBodyLarge"
                android:textColor="?attr/colorOnSurface" />

        </com.google.android.material.card.MaterialCardView>

        <com.google.android.material.button.MaterialButton
            android:id="@+id/settings_reset_dialog_confirm_button"
            style="@style/Widget.FreeAirRadio.DialogPrimaryButton"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/dialog_primary_button_margin_top"
            android:text="@string/settings_reset_confirm" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/settings_reset_dialog_close_button"
            style="@style/Widget.FreeAirRadio.DialogSecondaryButton"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/dialog_secondary_button_margin_top"
            android:text="@string/station_details_close" />

    </LinearLayout>

</com.google.android.material.card.MaterialCardView>
