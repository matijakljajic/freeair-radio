<?xml version="1.0" encoding="utf-8"?>
<com.google.android.material.card.MaterialCardView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    style="@style/Widget.FreeAirRadio.DialogCard"
    android:layout_width="match_parent"
    android:layout_height="wrap_content">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="@dimen/dialog_content_padding">

        <TextView
            android:id="@+id/settings_choice_dialog_title"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginHorizontal="@dimen/dialog_title_horizontal_margin"
            android:breakStrategy="balanced"
            android:gravity="center"
            android:textAlignment="center"
            android:textAppearance="@style/TextAppearance.FreeAirRadio.DialogTitle" />

        <com.google.android.material.card.MaterialCardView
            style="@style/Widget.FreeAirRadio.DialogSectionCard"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/dialog_section_margin_top">

            <com.google.android.material.textfield.TextInputLayout
                style="@style/Widget.Material3.TextInputLayout.OutlinedBox.ExposedDropdownMenu"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:padding="@dimen/dialog_section_padding"
                android:hint="@string/settings_top_stations_location_picker_hint">

                <com.google.android.material.textfield.MaterialAutoCompleteTextView
                    android:id="@+id/settings_choice_dialog_input"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:completionThreshold="0"
                    android:inputType="textCapWords"
                    android:maxLines="1"
                    android:popupBackground="@drawable/bg_dialog_dropdown_popup" />

            </com.google.android.material.textfield.TextInputLayout>

        </com.google.android.material.card.MaterialCardView>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/dialog_primary_button_margin_top"
            android:orientation="horizontal">

            <com.google.android.material.button.MaterialButton
                android:id="@+id/settings_choice_dialog_close_button"
                style="@style/Widget.FreeAirRadio.DialogSecondaryButton"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="@string/station_details_close" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/settings_choice_dialog_confirm_button"
                style="@style/Widget.FreeAirRadio.DialogPrimaryButton"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginStart="10dp"
                android:layout_weight="1"
                android:text="@string/dialog_select" />

        </LinearLayout>

    </LinearLayout>

</com.google.android.material.card.MaterialCardView>
