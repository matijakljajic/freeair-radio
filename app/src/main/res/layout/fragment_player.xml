<?xml version="1.0" encoding="utf-8"?>
<com.google.android.material.card.MaterialCardView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    app:cardCornerRadius="20dp"
    app:cardElevation="2dp"
    app:strokeColor="?attr/colorOutline"
    app:strokeWidth="1dp">

    <androidx.constraintlayout.widget.ConstraintLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:minHeight="72dp">

        <ImageView
            android:id="@+id/player_station_favicon"
            style="@style/Widget.FreeAirRadio.StationFaviconImage"
            android:contentDescription="@null"
            android:importantForAccessibility="no"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintBottom_toBottomOf="parent" />

        <LinearLayout
            android:id="@+id/player_station_text_container"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingStart="12dp"
            android:paddingTop="16dp"
            android:paddingEnd="0dp"
            android:paddingBottom="16dp"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintEnd_toStartOf="@id/player_button_container"
            app:layout_constraintStart_toEndOf="@id/player_station_favicon"
            app:layout_constraintTop_toTopOf="parent">

            <com.matijakljajic.freeairradio.ui.util.MarqueeTextView
                android:id="@+id/player_station_name"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:ellipsize="marquee"
                android:marqueeRepeatLimit="marquee_forever"
                android:text="@string/player_no_station_selected"
                android:textAppearance="?attr/textAppearanceTitleLarge"
                android:textSize="18sp"
                android:textStyle="bold"
                tools:ignore="VisualLintSystemUi"
                tools:text="Random Station" />

            <com.matijakljajic.freeairradio.ui.util.MarqueeTextView
                android:id="@+id/player_now_playing"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="6dp"
                android:ellipsize="marquee"
                android:marqueeRepeatLimit="marquee_forever"
                android:minLines="1"
                android:visibility="invisible"
                tools:text="{Artist - Track}"
                tools:visibility="visible" />

        </LinearLayout>

        <FrameLayout
            android:id="@+id/player_button_container"
            android:layout_width="48dp"
            android:layout_height="48dp"
            android:layout_marginStart="16dp"
            android:layout_marginEnd="16dp"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintTop_toTopOf="parent">

            <com.google.android.material.button.MaterialButton
                android:id="@+id/player_play_stop_button"
                style="@style/Widget.FreeAirRadio.NavPillButton"
                android:layout_width="48dp"
                android:layout_height="48dp"
                android:layout_gravity="center"
                android:contentDescription="@string/player_play_button"
                android:enabled="false"
                android:insetTop="0dp"
                android:insetBottom="0dp"
                app:cornerRadius="24dp"
                app:icon="@drawable/ic_play"
                app:iconGravity="textStart"
                app:iconPadding="0dp"
                app:iconSize="30dp"
                app:iconTint="@color/nav_pill_text_color"
                tools:ignore="VisualLintSystemUi,VisualLintOverlap" />

            <com.google.android.material.progressindicator.CircularProgressIndicator
                android:id="@+id/player_play_stop_loading_indicator"
                android:layout_width="48dp"
                android:layout_height="48dp"
                android:layout_gravity="center"
                android:importantForAccessibility="no"
                android:indeterminate="true"
                android:visibility="gone"
                app:indicatorColor="?attr/colorPrimaryContainer"
                app:indicatorInset="0dp"
                app:indicatorSize="48dp"
                app:trackColor="?attr/colorOutline"
                app:trackThickness="3dp"
                tools:visibility="visible" />

        </FrameLayout>

    </androidx.constraintlayout.widget.ConstraintLayout>

</com.google.android.material.card.MaterialCardView>
