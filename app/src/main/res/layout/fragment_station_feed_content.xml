<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/station_feed_content_root"
    android:layout_width="match_parent"
    android:layout_height="match_parent">

    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/station_feed_recycler_view"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:clipToPadding="false"
        android:paddingStart="16dp"
        android:paddingEnd="16dp"
        tools:listitem="@layout/item_station" />

    <LinearLayout
        android:id="@+id/station_feed_state_container"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:gravity="center"
        android:orientation="vertical"
        android:visibility="gone">

        <ProgressBar
            android:id="@+id/station_feed_loading_view"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:visibility="gone" />

        <LinearLayout
            android:id="@+id/station_feed_error_container"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center_horizontal"
            android:orientation="vertical"
            android:visibility="gone">

            <TextView
                android:id="@+id/station_feed_error_text"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/station_list_error"
                android:textAlignment="center" />

            <Button
                android:id="@+id/station_feed_retry_button"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                android:text="@string/station_list_retry" />
        </LinearLayout>

        <TextView
            android:id="@+id/station_feed_empty_view"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/station_list_empty"
            android:textAlignment="center"
            android:visibility="gone" />

    </LinearLayout>
</FrameLayout>
