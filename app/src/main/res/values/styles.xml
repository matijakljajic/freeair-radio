<?xml version="1.0" encoding="utf-8"?>
<resources>
    <style name="Widget.FreeAirRadio.NavPillButton" parent="Widget.Material3.Button">
        <item name="cornerRadius">16dp</item>
        <item name="android:minHeight">48dp</item>
        <item name="android:paddingTop">10dp</item>
        <item name="android:paddingBottom">10dp</item>
        <item name="android:insetTop">0dp</item>
        <item name="android:insetBottom">0dp</item>
        <item name="android:insetLeft">0dp</item>
        <item name="android:insetRight">0dp</item>
        <item name="backgroundTint">?attr/colorSurface</item>
        <item name="android:textColor">@color/nav_pill_text_color</item>
        <item name="strokeWidth">0dp</item>
        <item name="rippleColor">?attr/colorPrimaryContainer</item>
        <item name="android:textAllCaps">false</item>
    </style>

    <style name="Widget.FreeAirRadio.DialogCard" parent="">
        <item name="cardBackgroundColor">?attr/colorSurface</item>
        <item name="cardCornerRadius">@dimen/dialog_card_corner_radius</item>
        <item name="cardElevation">0dp</item>
        <item name="strokeColor">?attr/colorOutline</item>
        <item name="strokeWidth">1dp</item>
    </style>

    <style name="Widget.FreeAirRadio.DialogSectionCard" parent="">
        <item name="cardCornerRadius">@dimen/dialog_section_corner_radius</item>
        <item name="cardElevation">0dp</item>
        <item name="strokeColor">?attr/colorOutline</item>
        <item name="strokeWidth">1dp</item>
    </style>

    <style name="TextAppearance.FreeAirRadio.DialogTitle" parent="TextAppearance.Material3.HeadlineSmall">
        <item name="android:textStyle">bold</item>
    </style>

    <style name="Widget.FreeAirRadio.DialogPrimaryButton" parent="Widget.Material3.Button">
        <item name="android:insetTop">0dp</item>
        <item name="android:insetBottom">0dp</item>
        <item name="android:insetLeft">0dp</item>
        <item name="android:insetRight">0dp</item>
        <item name="android:textColor">?attr/colorOnPrimary</item>
        <item name="backgroundTint">?attr/colorPrimary</item>
        <item name="cornerRadius">@dimen/dialog_pill_corner_radius</item>
        <item name="rippleColor">?attr/colorOnPrimary</item>
    </style>

    <style name="Widget.FreeAirRadio.DialogSecondaryButton" parent="Widget.Material3.Button">
        <item name="android:insetTop">0dp</item>
        <item name="android:insetBottom">0dp</item>
        <item name="android:insetLeft">0dp</item>
        <item name="android:insetRight">0dp</item>
        <item name="android:textColor">?attr/colorOnSurface</item>
        <item name="backgroundTint">?attr/colorSurface</item>
        <item name="cornerRadius">@dimen/dialog_pill_corner_radius</item>
        <item name="rippleColor">?attr/colorPrimaryContainer</item>
        <item name="strokeColor">?attr/colorOutline</item>
        <item name="strokeWidth">1dp</item>
    </style>

    <style name="Widget.FreeAirRadio.StationFaviconImage" parent="">
        <item name="android:layout_width">@dimen/station_favicon_size</item>
        <item name="android:layout_height">0dp</item>
        <item name="android:background">?attr/colorSurfaceVariant</item>
        <item name="android:contentDescription">@null</item>
        <item name="android:importantForAccessibility">no</item>
        <item name="android:scaleType">centerCrop</item>
        <item name="android:src">@drawable/ic_station_favicon_default</item>
    </style>
</resources>
